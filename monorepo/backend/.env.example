# ============================================
# MORELATTO LANAS - CONFIGURACIÓN
# ============================================

# Database
DATABASE_URL=postgresql://usuario:password@localhost:5432/morelatto_db

# JWT Security
SECRET_KEY=tu_secret_key_muy_segura_cambiar_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_NAME=Morelatto API
DEBUG=True

# CORS - URLs de los frontends
FRONTEND_SISTEMA_URL=http://localhost:5173
FRONTEND_ECOMMERCE_URL=http://localhost:5174

# ============================================
# MERCADOPAGO - Pasarela de Pagos
# ============================================
# Obtener credenciales en: https://www.mercadopago.com.ar/developers
# 1. Crear cuenta de desarrollador
# 2. Ir a "Tus integraciones" > "Crear aplicación"
# 3. Copiar ACCESS TOKEN y PUBLIC KEY
#
# SANDBOX (Pruebas):
# - Access Token: TEST-xxxxx
# - Public Key: TEST-xxxxx
#
# PRODUCCIÓN:
# - Access Token: APP_USR-xxxxx
# - Public Key: APP_USR-xxxxx

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_URL=https://tu-dominio.com/api/payments/webhook
MERCADOPAGO_SUCCESS_URL=http://localhost:5174/checkout/success
MERCADOPAGO_FAILURE_URL=http://localhost:5174/checkout/failure
MERCADOPAGO_PENDING_URL=http://localhost:5174/checkout/pending

# ============================================
# STRIPE - Pasarela de Pagos Internacional
# ============================================
# Obtener credenciales en: https://dashboard.stripe.com/apikeys
# 1. Crear cuenta en Stripe
# 2. Ir a Developers > API keys
# 3. Copiar las keys (usa TEST keys para pruebas)
#
# TEST MODE:
# - Secret key: sk_test_xxxxx
# - Publishable key: pk_test_xxxxx
# - Webhook secret: whsec_xxxxx (obtener en Developers > Webhooks)
#
# LIVE MODE:
# - Secret key: sk_live_xxxxx
# - Publishable key: pk_live_xxxxx
# - Webhook secret: whsec_xxxxx

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# AFIP - Facturación Electrónica
# ============================================
# 1. Obtener certificado en AFIP:
#    - Ingresar a AFIP con clave fiscal
#    - Ir a "Administrador de Relaciones" > "Nueva Relación"
#    - Seleccionar servicio "wsfe" (Web Service Facturación Electrónica)
# 2. Generar certificado y clave privada
# 3. Subir certificado a AFIP
# 4. Descargar certificado .crt y guardar clave .key

AFIP_CUIT=20123456789
AFIP_CERT_PATH=certs/afip_cert.crt
AFIP_KEY_PATH=certs/afip_key.key
AFIP_PRODUCTION=False
AFIP_PUNTO_VENTA=1

# ============================================
# CARRIERS - Empresas de Envío
# ============================================

# ANDREANI
# Documentación: https://developers.andreani.com
# 1. Crear cuenta en https://clientes.andreani.com
# 2. Solicitar credenciales API
# 3. Obtener API Key y número de contrato

ANDREANI_API_KEY=
ANDREANI_CONTRACT=

# OCA
# Documentación: https://www.oca.com.ar/webservices
# Requiere contrato con OCA y solicitud de credenciales

OCA_API_KEY=
OCA_USERNAME=
OCA_PASSWORD=

# CORREO ARGENTINO - PAQ.AR API v2.0
# Documentación: API PAQ.AR v2.0
# URL TEST: https://apitest.correoargentino.com.ar/paqar/v1/
# URL PROD: https://api.correoargentino.com.ar/paqar/v1/
# 1. Contratar servicio PAQ.AR con Correo Argentino
# 2. Solicitar credenciales API (API Key y Agreement ID)
# 3. Configurar estas variables

PAQAR_API_KEY=
PAQAR_AGREEMENT_ID=
PAQAR_PRODUCTION=False

# ============================================
# CONFIGURACIÓN DE ENVÍO
# ============================================
# Dirección de origen para calcular envíos

ORIGIN_POSTAL_CODE=1000
ORIGIN_STREET=Av. Corrientes
ORIGIN_NUMBER=1234
ORIGIN_CITY=CABA
ORIGIN_PROVINCE=Buenos Aires
